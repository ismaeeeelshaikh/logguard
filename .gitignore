# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
.venv*/
venv/
env/

# Pytest and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Build and distribution artifacts
build/
dist/
*.egg-info/

# IDE/editor
.idea/
.vscode/

# OS metadata
*:Zone.Identifier

# Saved ML models & artifacts (large binary files)
ml/models/saved/
*.joblib
*.keras
*.h5
*.pkl

# Flink JARs (downloaded dependencies)
flink_jobs/jars/

# Data files (generated, not source code)
ml/data/*.parquet
ml/data/*.npy
*.parquet
*.npy

# Docker volumes and temp
*.log
/tmp/
